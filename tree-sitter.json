{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mage",
      "camelcase": "Mage",
      "title": "Mage",
      "scope": "source.ms",
      "file-types": ["ms"],
      "injection-regex": "^mage$",
      "class-name": "TreeSitterMage"
    }
  ],
  "metadata": {
    "version": "0.3.0",
    "license": "MIT",
    "description": "Mage grammar for tree-sitter",
    "authors": [
      {
        "name": "Aleksandr Kosachev",
        "email": "gohryt@rays-of-good.online",
        "url": "https://gohryt.online"
      }
    ],
    "links": {
      "repository": "https://github.com/MageLanguage/tree-sitter-mage"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
