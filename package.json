{
  "name": "tree-sitter-mage",
  "version": "0.4.0",
  "description": "Mage grammar for tree-sitter",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magelanguage/tree-sitter-mage.git"
  },
  "license": "MIT",
  "author": {
    "name": "Aleksandr Kosachev",
    "email": "gohryt@rays-of-good.online",
    "url": "https://gohryt.online"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "mage"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "dependencies": {
    "node-addon-api": "^8.5",
    "node-gyp-build": "^4.8"
  },
  "devDependencies": {
    "prebuildify": "^6.0",
    "tree-sitter-cli": "^0.26"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
