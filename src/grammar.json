{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mage",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "statement"
          },
          {
            "type": "STRING",
            "value": ";"
          }
        ]
      }
    },
    "statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_definition"
                },
                {
                  "type": "SYMBOL",
                  "name": "_as"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        }
      ]
    },
    "_definition": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "call"
        },
        {
          "type": "SYMBOL",
          "name": "name"
        }
      ]
    },
    "constant": {
      "type": "STRING",
      "value": ":"
    },
    "variable": {
      "type": "STRING",
      "value": "="
    },
    "_as": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "constant"
        },
        {
          "type": "SYMBOL",
          "name": "variable"
        }
      ]
    },
    "_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_string"
        },
        {
          "type": "SYMBOL",
          "name": "_number"
        },
        {
          "type": "SYMBOL",
          "name": "unary"
        },
        {
          "type": "SYMBOL",
          "name": "math"
        },
        {
          "type": "SYMBOL",
          "name": "call"
        },
        {
          "type": "SYMBOL",
          "name": "name"
        }
      ]
    },
    "escape": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^xu0-7]"
              },
              {
                "type": "PATTERN",
                "value": "[0-7]{1,3}"
              },
              {
                "type": "PATTERN",
                "value": "x[0-9a-fA-F]{2}"
              },
              {
                "type": "PATTERN",
                "value": "u[0-9a-fA-F]{4}"
              },
              {
                "type": "PATTERN",
                "value": "u\\{[0-9a-fA-F]+\\}"
              },
              {
                "type": "PATTERN",
                "value": "[\\r?][\\n\\u2028\\u2029]"
              }
            ]
          }
        ]
      }
    },
    "single_quoted_unescaped_string": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^'\\\\\\r\\n]+"
        }
      }
    },
    "double_quoted_unescaped_string": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^\"\\\\\\r\\n]+"
        }
      }
    },
    "single_quoted": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "single_quoted_unescaped_string"
                },
                "named": true,
                "value": "string"
              },
              {
                "type": "SYMBOL",
                "name": "escape"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "'"
        }
      ]
    },
    "double_quoted": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "double_quoted_unescaped_string"
                },
                "named": true,
                "value": "string"
              },
              {
                "type": "SYMBOL",
                "name": "escape"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "_string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "single_quoted"
        },
        {
          "type": "SYMBOL",
          "name": "double_quoted"
        }
      ]
    },
    "zero": {
      "type": "PATTERN",
      "value": "0"
    },
    "binary": {
      "type": "PATTERN",
      "value": "0[Bb][0-1]+"
    },
    "octal": {
      "type": "PATTERN",
      "value": "0[Oo][0-7]+"
    },
    "decimal": {
      "type": "PATTERN",
      "value": "0[Dd][0-9]+"
    },
    "hex": {
      "type": "PATTERN",
      "value": "0[Xx][0-9A-Fa-f]+"
    },
    "_number": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "zero"
        },
        {
          "type": "SYMBOL",
          "name": "binary"
        },
        {
          "type": "SYMBOL",
          "name": "octal"
        },
        {
          "type": "SYMBOL",
          "name": "decimal"
        },
        {
          "type": "SYMBOL",
          "name": "hex"
        }
      ]
    },
    "call": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_definition"
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_expression"
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "SYMBOL",
                        "name": "_expression"
                      }
                    ]
                  }
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": ","
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "add": {
      "type": "STRING",
      "value": "+"
    },
    "substract": {
      "type": "STRING",
      "value": "-"
    },
    "multiply": {
      "type": "STRING",
      "value": "*"
    },
    "divide": {
      "type": "STRING",
      "value": "/"
    },
    "modulo": {
      "type": "STRING",
      "value": "%"
    },
    "_arithmetic": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "add"
        },
        {
          "type": "SYMBOL",
          "name": "substract"
        },
        {
          "type": "SYMBOL",
          "name": "multiply"
        },
        {
          "type": "SYMBOL",
          "name": "divide"
        },
        {
          "type": "SYMBOL",
          "name": "modulo"
        }
      ]
    },
    "math": {
      "type": "PREC_RIGHT",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_expression"
          },
          {
            "type": "SYMBOL",
            "name": "_arithmetic"
          },
          {
            "type": "SYMBOL",
            "name": "_expression"
          }
        ]
      }
    },
    "unary": {
      "type": "PREC_RIGHT",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "add"
              },
              {
                "type": "SYMBOL",
                "name": "substract"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_expression"
          }
        ]
      }
    },
    "name": {
      "type": "PATTERN",
      "value": "\\w+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}